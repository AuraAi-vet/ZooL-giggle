{
  "ssg": "hugo",
  "mode": "hosted",
  "build": {
    "hugoVersion": "0.157.0",
    "rubyVersion": "3.4.8",
    "nodeVersion": "22",
    "denoVersion": "2.7.1",
    "install_command": "",
    "build_command": "hugo -b /",
    "output_path": "public",
    "environment_variables": [
      {
        "key": "HUGO_CACHEDIR",
        "value": "/usr/local/__site/src/.hugo_cache/"
      }
    ],
    "preserved_paths": "resources/,.hugo_cache/",
    "preserveOutput": true,
    "includeGit": true,
    "manually_configure_urls": true
  }
}