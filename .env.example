# ==============================================================================
# 🐾 ZooL | AI-Powered Vet Care - Environment Configuration Matrix
# ==============================================================================
# Copy this file to '.env' and fill in your secure credentials before building 
# or launching the application in production mode.
# ==============================================================================

# ------------------------------------------------------------------------------
# 🧠 Gemini AI Configuration
# ------------------------------------------------------------------------------
# Server-side API key for the Google Gen AI SDK
GEMINI_API_KEY=your_gemini_api_key_here

# Default Gemini model for text, vision, and diagnostic analysis
# Recommended: gemini-2.5-flash, gemini-3.1-flash-lite, or gemini-1.5-flash
VITE_GEMINI_MODEL=gemini-2.5-flash

# Volatile Live API WebRTC model fallback for the holographic voice companion (RuRu)
# Recommended: gemini-2.0-flash-exp or gemini-2.5-flash-native-audio-preview-09-2025
VITE_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025

# ------------------------------------------------------------------------------
# 🔥 Firebase Core Client Credentials
# ------------------------------------------------------------------------------
# These parameters will be used if the firebase-applet-config.json configuration
# is not loaded or for custom frontend-backend client bindings.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_key_for_notifications

# ------------------------------------------------------------------------------
# 📍 Location Services (OpenStreetMap / Overpass)
# ------------------------------------------------------------------------------
# ZooL is built on OpenStreetMap / Overpass API (fully free, rate-limited open source).
# No API key is needed. If you plan to switch to Google Maps Places API, set:
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
