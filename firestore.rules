rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isVerified() { return true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /users/{userId} {
      allow read, write: if isSignedIn() && isVerified() && request.auth.uid == userId;
    }

    match /pets/{petId} {
      allow read: if isSignedIn() && isVerified() && existing().ownerId == request.auth.uid;
      allow create: if isSignedIn() && isVerified() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isVerified() && existing().ownerId == request.auth.uid && incoming().ownerId == request.auth.uid;
      allow delete: if isSignedIn() && isVerified() && existing().ownerId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && isVerified() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isVerified() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isVerified() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && isVerified() && existing().userId == request.auth.uid;
    }

    match /healthRecords/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid
      );
    }

    match /quickLogs/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }

    match /petDocuments/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid
      );
    }

    match /appointments/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid || resource.data.providerId == request.auth.uid
      );
    }

    match /communityPosts/{id} {
      allow read, write: if isSignedIn() && isVerified(); // Assuming community posts are public to verified users
    }

    match /messages/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid
      );
    }

    match /licenses/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }

    match /trainingProgress/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }

    match /activityLogs/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }

    match /blockedSlots/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.providerId == request.auth.uid
      );
    }

    match /userTasks/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }

    match /services/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.providerId == request.auth.uid
      );
    }

    match /inventoryItems/{id} {
      allow read, write: if isSignedIn() && isVerified() && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }

    match /aiInteractionLogs/{id} {
      allow read: if false; 
      allow write: if isSignedIn() && isVerified();
    }
    
    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isVerified() && incoming().userId == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
