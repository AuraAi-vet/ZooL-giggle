rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // User can read/write their own profile
      allow read, write: if isSignedIn() && (isOwner(userId) || request.auth.token.email.matches('.*@.*'));
    }

    match /pets/{petId} {
      // Users can see and update their pets
      allow read, write: if isSignedIn();
    }

    match /appointments/{aptId} {
      // Users and clinics can see apps
      allow read, write: if isSignedIn();
    }

    match /serviceUpdates/{updateId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read, write: if isSignedIn();
    }

    match /activityLogs/{logId} {
      allow read, write: if isSignedIn();
    }

    match /gemmaKnowledgeBase/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
